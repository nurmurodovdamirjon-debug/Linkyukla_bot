# Telegram Bot Token (majburiy)
# @BotFather dan olingan token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Video cheklovlari
# Maksimum video davomiyligi (soniyalarda) - default: 6000 (100 daqiqa)
MAX_VIDEO_DURATION=6000

# Maksimum fayl hajmi (baytlarda) - default: 52428800 (50MB)
MAX_VIDEO_SIZE=52428800

# Yuklab olish katalogi
DOWNLOAD_DIR=downloads

# Log darajasi: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# YouTube cookies (ixtiyoriy)
# YouTube bot detection oldini olish uchun cookies.txt fayli mazmuni
# COOKIES_CONTENT=...

# Proxy sozlamalari (ixtiyoriy)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# Health check porti (Koyeb/Railway uchun)
PORT=8000
